# Database (PostgreSQL). Use Neon, Supabase, or local.
DATABASE_URL=postgresql://user:password@localhost:5432/hotchocolatefest

# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Optional: email provider for magic link (e.g. Resend)
# RESEND_API_KEY=re_xxxx

# Production: set to your app URL for auth redirects
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
