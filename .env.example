# Docker image
DOCKER_IMAGE=ghcr.io/aprilnickel/hotchocolatefestpassport:latest

# Database (PostgreSQL). Use Neon, Supabase, or local.
DATABASE_URL=postgresql://user:password@localhost:5432/hotchocolatefest
# DB credentials, used for automatic backups (see ops/database_backups.md):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=hotchocolatefest
# DB_USER=user
# PGPASSWORD=password
# DB_BACKUP_HEALTHCHECK_URL=https://hc-ping.com/your-uuid-here

# Production: set to your app URL for auth redirects
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
# To enable Google sign in:
# BETTER_AUTH_GOOGLE_CLIENT_ID=google-client-id
# BETTER_AUTH_GOOGLE_CLIENT_SECRET=google-client-secret

# To enable Posthog:
# NEXT_PUBLIC_POSTHOG_KEY=posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_API_KEY=posthog-api-key
# POSTHOG_PROJECT_ID=XXXXX

# To enable Sentry:
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn.com
# The SENTRY_AUTH_TOKEN variable is picked up by the Sentry Build Plugin.
# It's used for authentication when uploading source maps.
# SENTRY_AUTH_TOKEN=your-sentry-auth-token